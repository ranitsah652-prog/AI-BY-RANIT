import openai
import gradio as gr
import os
from datetime import datetime

# OpenAI API key set karo (ya .env file mein rakho)
openai.api_key = "your-openai-api-key-here"  # Apna API key yahan daalo

class ChatGPTClone:
    def __init__(self):
        self.conversation_history = []
    
    def chat(self, message, history):
        # History ko format karo
        messages = [{"role": "system", "content": "Tum ek helpful AI assistant ho. Hindi aur English dono mein baat kar sakte ho."}]
        
        # Previous conversation add karo
        for user_msg, assistant_msg in history:
            messages.append({"role": "user", "content": user_msg})
            if assistant_msg:
                messages.append({"role": "assistant", "content": assistant_msg})
        
        # Current message add karo
        messages.append({"role": "user", "content": message})
        
        try:
            # OpenAI API call
            response = openai.ChatCompletion.create(
                model="gpt-3.5-turbo",  # Ya gpt-4 use karo
                messages=messages,
                max_tokens=1000,
                temperature=0.7
            )
            
            ai_response = response.choices[0].message.content.strip()
            
            # History update karo
            self.conversation_history.append((message, ai_response))
            
            return ai_response
            
        except Exception as e:
            return f"Error: {str(e)}"

# Gradio Interface
def create_interface():
    chatbot = ChatGPTClone()
    
    def respond(message, history):
        bot_message = chatbot.chat(message, history)
        history.append((message, bot_message))
        return history, ""
    
    with gr.Blocks(title="ChatGPT Clone", theme=gr.themes.Soft()) as demo:
        gr.Markdown("# 🤖 ChatGPT Clone")
        gr.Markdown("**Apna OpenAI API key code mein daal kar use karo!**")
        
        chatbot_interface = gr.ChatInterface(
            respond,
            title="Baat karo...",
            description="ChatGPT jaisa AI assistant",
            theme=gr.themes.Soft(),
            examples=[
                "Hello, kaise ho?",
                "Python mein factorial kaise banaye?",
                "Aaj ka weather kaisa hai?",
                "Ek joke sunao!"
            ]
        )
    
    return demo

if __name__ == "__main__":
    demo = create_interface()
    demo.launch(share=True, server_name="0.0.0.0", server_port=7860)
